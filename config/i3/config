bindsym $mod+Shift+BackSpace move scratchpad
bindsym $mod+BackSpace scratchpad show

# Start i3bar to display a workspace bar (plus the system information i3status
# finds out, if available)
bar {
	#tray_output primary
	colors {
		background $color0
		statusline $color14
		separator  $color0

		# Type             border  background font
		focused_workspace  $color14 $color0 $color14
		active_workspace   $color0 $color0 $color14
		inactive_workspace $color0 $color0 $color14
		urgent_workspace   $color15 $color0 $color14

		#background #000000
		#statusline #ffffff
		#separator #000000

		## Type             border  background font
		#focused_workspace  #5294E2 #202020 #ffffff
		#active_workspace   #000000 #202020 #ffffff
		#inactive_workspace #000000 #000000 #ffffff
		#urgent_workspace   #aa0000 #990000 #ffffff
	}
	#status_command i3blocks -c ~/.config/i3/i3blocks.conf
	status_command i3status -c ~/.config/sway/i3status.conf
	position bottom
}

