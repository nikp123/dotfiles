bindsym XF86AudioPlay   exec ~/.config/scripts/playerctl play-pause
bindsym XF86AudioPrev   exec ~/.config/scripts/playerctl previous
bindsym XF86AudioNext   exec ~/.config/scripts/playerctl next
bindsym $mod+p          exec ~/.config/scripts/playerctl play-pause
