# Please see https://i3wm.org/docs/userguide.html for a complete reference!

set $mod Mod4

# Font for window titles. Will also be used by the bar unless a different font
# is used in the bar {} block below.
font pango:Terminus (TTF) 12

# This font is widely installed, provides lots of unicode glyphs, right-to-left
# text rendering and scalability on retina/hidpi displays (thanks to pango).
#font pango:DejaVu Sans Mono 8

# More appearance settings
default_border pixel 3
default_floating_border pixel 3
for_window [title="Microsoft Teams Notification"] floating enable
for_window [class=".*"] border pixel 3
for_window [class="XAVA"] floating enable
for_window [class="origin.exe"] floating enable
for_window [title="Brightness control"] floating enable
for_window [title="Steam - News.*"] kill
for_window [title="Friends List" class="Steam"] kill

# The combination of xss-lock, nm-applet and pactl is a popular choice, so
# they are included here as an example. Modify as you see fit.
set $term alacritty
set $browser firefox
set $fileman caja --no-desktop --browser /home/nikp123
set $pdf ~/.config/sway/scripts/ib

# xss-lock grabs a logind suspend inhibit lock and will use i3lock to lock the
# screen before suspend. Use loginctl lock-session to lock your screen.
#exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork

# NetworkManager is the most popular way to manage wireless networks on Linux,
# and nm-applet is a desktop environment-independent system tray GUI for it.
#exec --no-startup-id nm-applet

# Use pactl to adjust volume in PulseAudio.
bindsym XF86AudioRaiseVolume       exec pamixer -ui 2 && pamixer --get-volume > $I3SOCK.xob
bindsym XF86AudioLowerVolume       exec pamixer -ud 2 && pamixer --get-volume > $I3SOCK.xob
bindsym XF86AudioMute              exec pamixer --toggle-mute && ( pamixer --get-mute && echo 0 > $I3SOCK.xob ) || pamixer --get-volume > $I3SOCK.xob

bindsym Shift+XF86AudioRaiseVolume exec pamixer --default-source -ui 2 && pamixer --default-source --get-volume > $I3SOCK.xob
bindsym Shift+XF86AudioLowerVolume exec pamixer --default-source -ud 2 && pamixer --default-source --get-volume > $I3SOCK.xob
# These two should be the same
bindsym Shift+XF86AudioMute        exec pamixer --default-source --toggle-mute && ( pamixer --default-source --get-mute && echo 0 > $I3SOCK.xob ) || pamixer --default-source --get-volume > $I3SOCK.xob
bindsym XF86AudioMicMute           exec pamixer --default-source --toggle-mute && ( pamixer --default-source --get-mute && echo 0 > $I3SOCK.xob ) || pamixer --default-source --get-volume > $I3SOCK.xob

